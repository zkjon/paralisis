<button
  id="pulsar-para-leer"
  type="button"
  class="w-12 h-12 rounded-full cursor-pointer flex items-center justify-center text-black dark:text-gray-200"
  aria-label="Leer página"
>
  <span id="icono-lectura" class="flex items-center justify-center">
    <!-- Icono hablar -->
    <svg
      id="icono-play"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 33.283 33.283"
      class="w-8 h-8"
      aria-hidden="true"
    >
      <path
        fill="currentColor"
        d="M3.805,8.964c-4.24,3.229-5.061,9.283-1.832,13.523s9.284,5.061,13.524,1.832
        c1.902-1.449,3.109-3.469,3.579-5.637c-1.646,0.028-4.01-0.21-6.988-1.263c3.21-0.523,5.394-2.227,6.745-3.718
        c-0.327-1.02-0.818-2.006-1.505-2.907C14.1,6.556,8.044,5.735,3.805,8.964z M11.189,12.084c-0.668,0.508-1.621,0.379-2.127-0.288
        c-0.508-0.667-0.378-1.618,0.288-2.127c0.668-0.508,1.62-0.379,2.127,0.288S11.855,11.577,11.189,12.084z M21.468,16.289
        c0,0.592-0.09,1.152-0.225,1.685l2.238,1.786c0.349-1.065,0.547-2.235,0.547-3.471c0-1.332-0.241-2.58-0.645-3.71l-2.228,1.663
        C21.356,14.872,21.468,15.564,21.468,16.289z M27.632,10.012l-2.236,1.67c0.511,1.395,0.806,2.955,0.806,4.608
        c0,1.575-0.269,3.067-0.732,4.411l2.205,1.758c0.688-1.862,1.089-3.952,1.089-6.167C28.76,14.03,28.349,11.9,27.632,10.012z
        M29.476,23.25l2.203,1.758c1.021-2.612,1.604-5.574,1.604-8.719c0-3.139-0.584-6.095-1.601-8.705l-2.236,1.671
        c0.81,2.114,1.275,4.501,1.275,7.034C30.724,18.793,30.267,21.155,29.476,23.25z"
      />
    </svg>

    <!-- Icono pause -->
    <svg
      id="icono-pause"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="w-8 h-8 hidden"
      aria-hidden="true"
    >
      <path
        fill="currentColor"
        d="M7 5h3v14H7zm7 0h3v14h-3z"
      />
    </svg>
  </span>
</button>

<script>
  const button = document.getElementById('pulsar-para-leer') as HTMLButtonElement;
  const iconoPlay = document.getElementById('icono-play') as HTMLElement;
  const iconoPause = document.getElementById('icono-pause') as HTMLElement;

  let utterance = null;
  let textoActual = '';
  let leyendo = false;
  let pausado = false;

  function mostrarIcono(estado: 'play' | 'pause') {
    if (estado === 'play') {
      iconoPlay.classList.remove('hidden');
      iconoPause.classList.add('hidden');
      button.setAttribute('aria-label', 'Leer página');
    }

    if (estado === 'pause') {
      iconoPlay.classList.add('hidden');
      iconoPause.classList.remove('hidden');
      button.setAttribute('aria-label', 'Pausar lectura');
    }
  }

  function obtenerTextoVisible() {
    const contenedor = document.querySelector('main, article, [role="main"]') || document.body;

    const elementosNoLeibles = ['SCRIPT', 'STYLE', 'NOSCRIPT', 'IFRAME', 'SVG'];

    const walker = document.createTreeWalker(
      contenedor,
      NodeFilter.SHOW_TEXT,
      {
        acceptNode(node) {
          const parent = node.parentElement;
          if (!parent) return NodeFilter.FILTER_REJECT;

          if (elementosNoLeibles.includes(parent.tagName)) {
            return NodeFilter.FILTER_REJECT;
          }

          const estilo = window.getComputedStyle(parent);
          if (estilo.display === 'none' || estilo.visibility === 'hidden') {
            return NodeFilter.FILTER_REJECT;
          }

          const texto = node.textContent != null ? node.textContent.trim() : '';
          if (!texto) {
            return NodeFilter.FILTER_REJECT;
          }

          return NodeFilter.FILTER_ACCEPT;
        }
      }
    );

    let textoCompleto = '';

    while (walker.nextNode()) {
      textoCompleto += walker.currentNode.textContent != null ? walker.currentNode.textContent.trim() : '' + '. ';
    }

    return textoCompleto.trim();
  }

  function iniciarLectura() {
    textoActual = obtenerTextoVisible();

    if (!textoActual) {
      alert('No hay texto para leer.');
      return;
    }

    utterance = new SpeechSynthesisUtterance(textoActual);
    utterance.lang = 'es-ES';
    utterance.rate = 1;
    utterance.pitch = 1;
    utterance.volume = 1;

    utterance.onstart = () => {
      leyendo = true;
      pausado = false;
      mostrarIcono('pause');
    };

    utterance.onend = () => {
      leyendo = false;
      pausado = false;
      utterance = null;
      mostrarIcono('play');
    };

    utterance.onerror = () => {
      leyendo = false;
      pausado = false;
      utterance = null;
      mostrarIcono('play');
    };

    speechSynthesis.cancel();
    speechSynthesis.speak(utterance);
  }

  button.addEventListener('click', (e) => {
    e.preventDefault();

    if (!('speechSynthesis' in window)) {
      alert('Tu navegador no soporta lectura en voz.');
      return;
    }

    if (!leyendo && !pausado) {
      iniciarLectura();
      return;
    }

    if (leyendo && !pausado) {
      speechSynthesis.pause();
      pausado = true;
      mostrarIcono('play');
      button.setAttribute('aria-label', 'Continuar lectura');
      return;
    }

    if (pausado) {
      speechSynthesis.resume();
      pausado = false;
      mostrarIcono('pause');
      return;
    }
  });

  window.addEventListener('beforeunload', () => {
    speechSynthesis.cancel();
  });
</script>